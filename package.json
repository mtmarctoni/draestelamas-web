{
  "name": "draestelamas",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "rm -rf node_modules/.vite node_modules/.astro/fonts .astro/fonts && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "checks": "rm -rf node_modules/.vite && pnpm lint && pnpm knip && pnpm depcruise && pnpm test && pnpm check && pnpm build",
    "clean": "rm -rf node_modules/.vite node_modules/.astro/fonts .astro/fonts dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "knip": "knip",
    "depcruise": "depcruise src tests",
    "test": "vitest run",
    "deploy": "pnpm build && wrangler deploy",
    "prepare": "simple-git-hooks",
    "astro": "astro"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec biome check --staged --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "astro": "^7.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.5.4",
    "dependency-cruiser": "^18.1.0",
    "knip": "^6.27.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
