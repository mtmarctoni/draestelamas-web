---
import type { Locale } from "../i18n";
import {
  defaultLocale,
  getTranslations,
  localeHreflang,
  locales,
  localizeUrl,
  ogLocale,
} from "../i18n";
import { robotsDirective } from "../lib/seo";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  imageAlt?: string;
  /** Pages that should stay out of search results (e.g. legal/privacy) even when the environment allows indexing. Links are still followed. */
  noindex?: boolean;
}

const { locale, title, description, imageAlt, noindex } = Astro.props;
const t = getTranslations(locale);
const site = Astro.site;
if (!site) throw new Error("`site` must be set in astro.config.mjs — canonical URLs depend on it.");
const urlFor = (loc: Locale) => new URL(localizeUrl(Astro.url.pathname, loc), site).href;
const ogImage = new URL("/og-image.jpg", site).href;
const envIndexable = import.meta.env.PUBLIC_ALLOW_INDEXING === "true";
const robotsContent = robotsDirective(envIndexable, noindex);
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Dra. Estela Mas Ródenas" />
<meta name="robots" content={robotsContent} />
<link rel="canonical" href={urlFor(locale)} />

{locales.map((loc) => <link rel="alternate" hreflang={localeHreflang[loc]} href={urlFor(loc)} />)}
<link rel="alternate" hreflang="x-default" href={urlFor(defaultLocale)} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Dra. Estela Mas" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={urlFor(locale)} />
<meta property="og:locale" content={ogLocale[locale]} />
{locales
  .filter((loc) => loc !== locale)
  .map((loc) => <meta property="og:locale:alternate" content={ogLocale[loc]} />)}
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt ?? t.hero.imageAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
