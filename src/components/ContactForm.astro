---
import type { Locale } from "../i18n";
import { getTranslations, privacyPath } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="contacto">
  <div class="section-inner contacto-inner">
    <h2 class="section-title fade-up">{t.contact.title}</h2>
    <div class="info-item fade-up">
      <div class="info-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <div>
        <div class="info-label">Email</div>
        <div class="info-val">{t.contact.email}</div>
      </div>
    </div>
    <div class="fade-up form-wrap">
      <p class="form-success is-hidden" id="form-success" role="status" hidden>
        {t.contact.success}
        <br />
        <button type="button" class="btn btn-secondary send-again-btn" id="send-again">{t.contact.sendAnother}</button>
      </p>
      <p class="form-error" id="form-error" role="alert" hidden>{t.contact.error}</p>
      <form
        class="contact-form"
        id="contact-form"
        novalidate
        data-sending={t.contact.sending}
        data-submit={t.contact.submit}
        data-error-name={t.contact.fieldErrors.name}
        data-error-surname={t.contact.fieldErrors.surname}
        data-error-email={t.contact.fieldErrors.email}
        data-error-message={t.contact.fieldErrors.message}
      >
        {/* LAYER 1: honeypot — visually removed, bots fill it, Zod rejects it. */}
        <div class="honeypot" aria-hidden="true">
          <label for="important_field">Do not fill this field</label>
          <input type="text" id="important_field" name="important_field" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="locale" value={locale} />
        <div class="form-row">
          <div class="field">
            <label for="name">{t.contact.labels.name}</label>
            <input type="text" id="name" name="name" required minlength="2" autocomplete="given-name" aria-describedby="name-error" />
            <p class="field-error" id="name-error" aria-live="polite" hidden></p>
          </div>
          <div class="field">
            <label for="surname">{t.contact.labels.surname}</label>
            <input type="text" id="surname" name="surname" required autocomplete="family-name" aria-describedby="surname-error" />
            <p class="field-error" id="surname-error" aria-live="polite" hidden></p>
          </div>
        </div>
        <div class="field">
          <label for="email">{t.contact.labels.email}</label>
          <input type="email" id="email" name="email" required autocomplete="email" aria-describedby="email-error" />
          <p class="field-error" id="email-error" aria-live="polite" hidden></p>
        </div>
        <div class="field">
          <label for="message">{t.contact.labels.message}</label>
          <textarea id="message" name="message" rows="6" required aria-describedby="message-error"></textarea>
          <p class="field-error" id="message-error" aria-live="polite" hidden></p>
        </div>
        {/* LAYER 3: Cloudflare Turnstile (disabled by default). To enable, add the
            widget below, allow challenges.cloudflare.com in the CSP (already done),
            and uncomment the verification block in src/actions/index.ts:
        <div class="cf-turnstile" data-sitekey="YOUR_TURNSTILE_SITE_KEY"></div>
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
        */}
        <p class="form-note">
          {t.contact.gdpr}
          <a href={privacyPath(locale)}>{t.contact.privacyLink}</a>
        </p>
        <p class="form-art13">{t.contact.art13}</p>
        <button type="submit" class="btn btn-primary submit-btn" id="submit-btn">{t.contact.submit}</button>
      </form>
    </div>
  </div>
</section>

<script>
  import { actions, isInputError } from "astro:actions";

  type Field = "name" | "surname" | "email" | "message";

  let submitting = false;

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const isEmailValid = (value: string) => EMAIL_RE.test(value.trim());
  const formSuccess = document.getElementById("form-success");
  const errorBox = document.getElementById("form-error");
  const submit = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const sendAgain = document.getElementById("send-again") as HTMLButtonElement | null;
  const nameInput = document.getElementById("name") as HTMLInputElement | null;
  const surnameInput = document.getElementById("surname") as HTMLInputElement | null;
  const emailInput = document.getElementById("email") as HTMLInputElement | null;
  const messageInput = document.getElementById("message") as HTMLTextAreaElement | null;
  const fieldInputs: Record<Field, HTMLInputElement | HTMLTextAreaElement | null> = {
    name: nameInput,
    surname: surnameInput,
    email: emailInput,
    message: messageInput,
  };

  function showFieldError(field: Field) {
    const input = fieldInputs[field];
    const errorEl = document.getElementById(`${field}-error`);
    if (!input || !errorEl || !form) return;
    const dataKey = `error${field.charAt(0).toUpperCase() + field.slice(1)}` as
      | "errorName"
      | "errorSurname"
      | "errorEmail"
      | "errorMessage";
    errorEl.textContent = form.dataset[dataKey] ?? "";
    errorEl.hidden = false;
    input.setAttribute("aria-invalid", "true");
    input.closest(".field")?.classList.add("invalid");
  }

  function hideFieldError(field: Field) {
    const input = fieldInputs[field];
    const errorEl = document.getElementById(`${field}-error`);
    if (!input || !errorEl) return;
    errorEl.textContent = "";
    errorEl.hidden = true;
    input.removeAttribute("aria-invalid");
    input.closest(".field")?.classList.remove("invalid");
  }

  function resetButton() {
    if (!submit || !form) return;
    submit.disabled = false;
    submit.textContent = form.dataset.submit ?? "";
  }

  function validateFields(): Field | null {
    if (nameInput && nameInput.value.trim().length < 2) {
      showFieldError("name");
    } else {
      hideFieldError("name");
    }

    if (surnameInput && surnameInput.value.trim().length < 1) {
      showFieldError("surname");
    } else {
      hideFieldError("surname");
    }

    if (emailInput && !isEmailValid(emailInput.value)) {
      showFieldError("email");
    } else {
      hideFieldError("email");
    }

    if (messageInput && messageInput.value.trim().length < 1) {
      showFieldError("message");
    } else {
      hideFieldError("message");
    }

    if (nameInput && nameInput.value.trim().length < 2) return "name";
    if (surnameInput && surnameInput.value.trim().length < 1) return "surname";
    if (emailInput && !isEmailValid(emailInput.value)) return "email";
    if (messageInput && messageInput.value.trim().length < 1) return "message";
    return null;
  }

  function clearAllFieldErrors() {
    const fields: Field[] = ["name", "surname", "email", "message"];
    for (const f of fields) hideFieldError(f);
  }

  const prefersReducedMotion =
    typeof window !== "undefined" && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function fadeOut(el: HTMLElement): Promise<void> {
    if (prefersReducedMotion) {
      el.classList.add("is-hidden");
      return Promise.resolve();
    }
    return new Promise((resolve) => {
      let resolved = false;
      const done = () => {
        if (resolved) return;
        resolved = true;
        resolve();
      };
      el.addEventListener("transitionend", done, { once: true });
      setTimeout(done, 250);
      el.classList.add("is-hidden");
    });
  }

  function fadeIn(el: HTMLElement): Promise<void> {
    if (prefersReducedMotion) {
      el.classList.remove("is-hidden");
      return Promise.resolve();
    }
    return new Promise((resolve) => {
      let resolved = false;
      const done = () => {
        if (resolved) return;
        resolved = true;
        resolve();
      };
      el.addEventListener("transitionend", done, { once: true });
      setTimeout(done, 250);
      el.classList.remove("is-hidden");
    });
  }

  async function showSuccess() {
    if (!form || !formSuccess) return;
    await fadeOut(form);
    form.hidden = true;
    formSuccess.hidden = false;
    await fadeIn(formSuccess);
    sendAgain?.focus();
  }

  async function resetToSendAnother() {
    if (!form || !formSuccess) return;
    await fadeOut(formSuccess);
    formSuccess.hidden = true;
    clearAllFieldErrors();
    resetButton();
    form.reset();
    form.hidden = false;
    await fadeIn(form);
    nameInput?.focus();
  }

  nameInput?.addEventListener("blur", () => {
    if (nameInput.value.trim().length < 2) {
      showFieldError("name");
    } else {
      hideFieldError("name");
    }
  });

  surnameInput?.addEventListener("blur", () => {
    if (surnameInput.value.trim().length < 1) {
      showFieldError("surname");
    } else {
      hideFieldError("surname");
    }
  });

  emailInput?.addEventListener("blur", () => {
    if (!isEmailValid(emailInput.value)) {
      showFieldError("email");
    } else {
      hideFieldError("email");
    }
  });

  messageInput?.addEventListener("blur", () => {
    if (messageInput.value.trim().length < 1) {
      showFieldError("message");
    } else {
      hideFieldError("message");
    }
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!submit || submitting) return;

    const firstInvalid = validateFields();
    if (firstInvalid) {
      const input = fieldInputs[firstInvalid];
      input?.focus();
      return;
    }

    submitting = true;
    submit.disabled = true;
    submit.textContent = form.dataset.sending ?? "";
    errorBox?.setAttribute("hidden", "");

    try {
      const { error } = await actions.contact(new FormData(form));

      if (!error) {
        await showSuccess();
        return;
      }

      if (isInputError(error)) {
        if (error.fields.name) showFieldError("name");
        if (error.fields.surname) showFieldError("surname");
        if (error.fields.email) showFieldError("email");
        if (error.fields.message) showFieldError("message");
        const firstField: Field | null = error.fields.name
          ? "name"
          : error.fields.surname
            ? "surname"
            : error.fields.email
              ? "email"
              : error.fields.message
                ? "message"
                : null;
        if (firstField) {
          const input = fieldInputs[firstField];
          input?.focus();
        }
      } else {
        errorBox?.removeAttribute("hidden");
      }
    } catch {
      errorBox?.removeAttribute("hidden");
    } finally {
      submitting = false;
      resetButton();
    }
  });

  sendAgain?.addEventListener("click", () => {
    resetToSendAnother();
  });
</script>

<style>
  #contacto {
    background: #fff;
  }
  .contacto-inner {
    max-width: 780px;
  }
  .info-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 2rem;
  }
  .info-icon {
    width: 34px;
    height: 34px;
    flex-shrink: 0;
    background: var(--color-sand);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .info-icon svg {
    width: 15px;
    height: 15px;
    stroke: var(--color-navy);
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
  }
  .info-label {
    font-size: 0.65rem;
    color: var(--color-burnt);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .info-val {
    font-size: 0.88rem;
    color: var(--color-ink);
    margin-top: 2px;
  }
  .form-wrap {
    transition-delay: 0.1s;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: opacity 0.18s ease-out;
  }
  .contact-form.is-hidden {
    opacity: 0;
    pointer-events: none;
  }
  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .field label {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 500;
  }
  .field input,
  .field textarea {
    font-family: var(--font-body);
    font-size: 0.87rem;
    color: var(--color-ink);
    background: var(--color-ivory);
    border: 1px solid rgba(43, 74, 106, 0.15);
    border-radius: 2px;
    padding: 0.62rem 0.82rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus {
    border-color: var(--color-sky);
    box-shadow: 0 0 0 3px rgba(74, 123, 155, 0.1);
  }
  .field textarea {
    min-height: 140px;
  }
  .form-note {
    font-size: 0.69rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
  .form-note :global(a) {
    color: var(--color-sky);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .form-art13 {
    font-size: 0.65rem;
    color: var(--color-muted);
    line-height: 1.6;
    opacity: 0.8;
    margin-top: 0.5rem;
  }
  .form-success {
    background: rgba(181, 98, 42, 0.08);
    border: 1px solid var(--color-burnt);
    border-radius: 4px;
    padding: 1.5rem;
    color: var(--color-burnt);
    font-size: 0.87rem;
    text-align: center;
    transition: opacity 0.18s ease-out;
  }
  .form-success.is-hidden {
    opacity: 0;
    pointer-events: none;
  }
  .send-again-btn {
    margin-top: 1rem;
    font-size: 0.8rem;
    padding: 0.5rem 1.2rem;
    border: 1px solid var(--color-burnt);
    background: transparent;
    color: var(--color-burnt);
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .send-again-btn:hover {
    background: var(--color-burnt);
    color: #fff;
  }
  .form-error {
    background: rgba(198, 11, 30, 0.06);
    border: 1px solid #c0392b;
    border-radius: 4px;
    padding: 1rem 1.5rem;
    color: #c0392b;
    font-size: 0.87rem;
    text-align: center;
    margin-bottom: 1rem;
  }
  .form-success[hidden],
  .form-error[hidden],
  .field-error[hidden] {
    display: none;
  }
  .field-error {
    font-size: 0.75rem;
    color: #c0392b;
    margin: 0;
  }
  .field.invalid input,
  .field.invalid textarea {
    border-color: #c0392b;
  }
  .submit-btn {
    width: 100%;
    margin-top: 0.5rem;
  }
  @media (max-width: 960px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
