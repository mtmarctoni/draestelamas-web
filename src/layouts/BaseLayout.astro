---
import { Font, getImage } from "astro:assets";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SEO from "../components/SEO.astro";
import type { Locale } from "../i18n";
import { getTranslations } from "../i18n";
import "../styles/global.css";
import heroImg from "../assets/img/hero-obra.png";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  preloadHero?: boolean;
  schemaType?: "physician" | "blog";
  blogData?: { title: string; date: string; author: string; image?: string };
}

const { locale } = Astro.props;
const preloadHero = Astro.props.preloadHero ?? true;
const t = getTranslations(locale);
const title = Astro.props.title ?? t.meta.title;
const description = Astro.props.description ?? t.meta.description;

const heroOptimized = await getImage({
  src: heroImg,
  width: 420,
  height: 310,
  format: "webp",
  quality: 60,
});

const schemaType = Astro.props.schemaType ?? "physician";
let jsonLd: string;

if (schemaType === "blog" && Astro.props.blogData) {
  jsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: Astro.props.blogData.title,
    datePublished: Astro.props.blogData.date,
    author: { "@type": "Person", name: Astro.props.blogData.author },
    ...(Astro.props.blogData.image && { image: Astro.props.blogData.image }),
  });
} else {
  jsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Physician",
    name: "Dra. Estela Mas Ródenas",
    medicalSpecialty: "Nephrology",
    description,
    url: Astro.site?.href,
    availableService: {
      "@type": "MedicalProcedure",
      name: "Consulta nefrològica online",
    },
    knowsLanguage: ["ca", "es", "en"],
  });
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.jpg" />
    <Font cssVariable="--font-cormorant" preload />
    <Font cssVariable="--font-inter" preload />
    {preloadHero && <link rel="preload" as="image" href={heroOptimized.src} media="(min-width: 961px)" />}
    <SEO locale={locale} title={title} description={description} />
    <meta name="build-commit" content={import.meta.env.PUBLIC_GIT_SHA ?? "dev"} />
    <script type="application/ld+json" is:inline set:html={jsonLd} />
  </head>
  <body>
    <Header locale={locale} />
    <main><slot /></main>
    <Footer locale={locale} />
  </body>
</html>
